# App runtime mode
NODE_ENV=production

# API container port (host and app env)
PORT=3000

# Web UI host port (mapped to nginx :80 in container)
WEB_PORT=8080

# Postgres bootstrap variables (used by postgres service)
POSTGRES_DB=image_processor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432

# Redis host port
REDIS_PORT=6379

# MinIO bootstrap variables and host ports
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Database connection URL for app services
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@postgres:5432/image_processor

# Redis connection URL for job queue and caching
REDIS_URL=redis://redis:6379

# S3-compatible storage endpoint (internal service URL)
S3_ENDPOINT=http://minio:9000

# Public storage endpoint (used for URLs returned to clients)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# AWS region or MinIO equivalent
S3_REGION=us-east-1

# S3 bucket name for storing images
S3_BUCKET=image-processor

# S3 access key ID
S3_ACCESS_KEY_ID=minioadmin

# S3 secret access key
S3_SECRET_ACCESS_KEY=minioadmin

# Force path-style URLs for MinIO compatibility (true for MinIO, false for AWS)
S3_FORCE_PATH_STYLE=true

# Maximum upload file size in bytes (e.g., 20MB = 20971520)
MAX_UPLOAD_BYTES=20971520

# Public-facing API URL for frontend (used by web app to call API)
PUBLIC_API_URL=http://localhost:3000

# Worker parallelism
WORKER_CONCURRENCY=4

# Optional container names used by docker compose
POSTGRES_CONTAINER_NAME=image-processor-postgres
REDIS_CONTAINER_NAME=image-processor-redis
MINIO_CONTAINER_NAME=image-processor-minio
MINIO_INIT_CONTAINER_NAME=image-processor-minio-init
MIGRATE_CONTAINER_NAME=image-processor-migrate
SERVER_CONTAINER_NAME=image-processor-server
WORKER_CONTAINER_NAME=image-processor-worker
WEB_CONTAINER_NAME=image-processor-web
