# Database connection URL for Postgres
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/image_processor

# Redis connection URL for job queue and caching
REDIS_URL=redis://localhost:6379

# S3-compatible storage endpoint
S3_ENDPOINT=http://localhost:9000

# AWS region or MinIO equivalent
S3_REGION=us-east-1

# S3 bucket name for storing images
S3_BUCKET=image-processor

# S3 access key ID
S3_ACCESS_KEY_ID=minioadmin

# S3 secret access key
S3_SECRET_ACCESS_KEY=minioadmin

# Force path-style URLs for MinIO compatibility (true for MinIO, false for AWS)
S3_FORCE_PATH_STYLE=true

# Server port (Hono/Bun app)
PORT=3000

# Maximum upload file size in bytes (e.g., 20MB = 20971520)
MAX_UPLOAD_BYTES=20971520

# Public-facing API URL for frontend (used by web app to call API)
PUBLIC_API_URL=http://localhost:3000